# 依赖
node_modules
**/node_modules

# 构建产物
.next
**/.next
out
**/out
dist
**/dist
build
**/build

# 开发文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 环境变量（不要提交到镜像）
.env
.env.*
!.env.example

# Git
.git
.gitignore

# IDE
.idea
.vscode
*.swp
*.swo

# 测试
coverage
**/__tests__
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx

# 文档
*.md
docs

# 移动端应用（不需要在 web docker 中）
apps/mobile

# 其他
.DS_Store
Thumbs.db
*.pem
.turbo

# 备份/打包文件（避免污染 build context）
*.tar
*.tar.part_*
*.bak
*.backup
backup_*.dump
backup_*.sql
*.dump

# 移除的功能备份（commit 历史可恢复，build 时不需要）
_backup
**/_backup

# 杂项 SQL 文件（生产 prisma migrate 走 schema 流程，不需要 ad-hoc SQL 进 image）
/add_*.sql
/update_*.sql

# 开发用的 nginx 静态、备份 docker-compose 等
nginx/static
docker-compose.yml.bak

# 仓库里的部署/调试脚本（容器内不需要）
deploy.sh
