// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ✅ 活动表
model Event {
  id        Int      @id @default(autoincrement())
  name      String
  category  String   @default("concert")  // concert(演唱会), festival(音乐节), exhibition(展览), musicale(音乐会), show(演出), sports(体育赛事), other(其他)
  city      String
  venue     String
  date      String   // 演出日期
  time      String   // 演出时间

  // 售票状态和时间控制
  saleStatus    String   @default("on_sale")  // not_started(未开售), on_sale(售票中), paused(暂停售票), sold_out(已售罄), ended(已结束)
  saleStartTime DateTime @default(now())      // 开售时间
  saleEndTime   DateTime @default(now())      // 停售时间（通常为演出前1天）

  cover     String
  artist    String   // 艺人/主办方/策展人
  desc      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tiers     Tier[]
  collectibles Collectible[]
  posts     Post[]
  followers EventFollow[]
  notifications Notification[]
  homepageSections HomepageSectionEvent[]

  @@map("events")
  @@index([category])
  @@index([date])
}

// ✅ 票档表
model Tier {
  id        Int      @id @default(autoincrement())
  eventId   Int
  name      String
  price     Int
  capacity  Int
  remaining Int
  sold      Int      @default(0) // 已售数量
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  // 注：Order.tierId 存储为 String，不建立外键关联

  @@map("tiers")
  @@index([eventId])
}

// ✅ 锁票表
model Hold {
  id        String   @id
  eventId   String
  tierId    String
  qty       Int
  expireAt  BigInt
  createdAt BigInt

  @@map("holds")
  @@index([eventId, tierId])
  @@index([expireAt])
}

// ✅ 订单表
model Order {
  id              String   @id
  userId          String
  eventId         String
  tierId          String
  qty             Int
  holdId          String
  status          String
  createdAt       BigInt
  paidAt          BigInt?

  // ============ 支付信息（新增）============
  paymentMethod   String?  // wechat, alipay, mock
  transactionId   String?  // 第三方支付交易号
  refundedAt      BigInt?  // 退款时间
  refundId        String?  // 退款单号

  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  // 注：tierId 存储为 String，不建立外键关联，在代码中处理类型转换
  tickets   Ticket[]

  @@map("orders")
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([transactionId])
}

// ✅ 票表
model Ticket {
  id          String   @id @default(uuid())
  ticketCode  String   @unique
  seatNumber  String?
  eventId     Int
  tierId      Int
  holdId      String?
  orderId     String?
  userId      String?
  status      String
  price       Int

  purchasedAt DateTime?
  usedAt      DateTime?
  refundedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // 关联
  order       Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("tickets")
  @@index([eventId])
  @@index([tierId])
  @@index([holdId])
  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@index([ticketCode])
  @@index([eventId, tierId, status, seatNumber])
}

// ✅ 用户表（扩展个人信息）
model User {
  id            String   @id @default(uuid())
  email         String?  @unique
  phone         String?  @unique
  password      String?
  nickname      String?
  avatar        String?

  // 第三方登录
  wechatOpenId  String?  @unique
  qqOpenId      String?  @unique
  authProvider  String   @default("local")

  // 用户角色
  role          String   @default("user")

  // ============ 封禁状态 ============
  isBanned        Boolean  @default(false)
  bannedAt        DateTime?
  bannedReason    String?  @db.Text

  // ============ 个人信息扩展 ============
  bio                 String?  @db.Text // 个人简介
  coverImage          String?  // 个人主页封面图
  website             String?  // 个人网站
  location            String?  // 所在地

  // ============ 认证系统 ============
  isVerified          Boolean  @default(false)
  verifiedType        String?  // celebrity, artist, organizer, official
  verifiedAt          DateTime?
  verificationBadge   String?  // 认证徽章图标URL

  // ============ 统计字段 ============
  collectibleCount    Int      @default(0)
  followerCount       Int      @default(0)
  followingCount      Int      @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // 关联
  orders        Order[]
  tickets       Ticket[]
  loginLogs     LoginLog[]
  sessions      UserSession[]

  // 收藏品
  userCollectibles UserCollectible[]

  // 社交
  posts         Post[]
  likes         PostLike[]
  comments      Comment[]
  reports       PostReport[]
  favoritePosts PostFavorite[]
  sentMessages  Message[]      @relation("SentMessages")
  receivedMessages Message[]   @relation("ReceivedMessages")
  conversations ConversationParticipant[]

  // 关注
  followedEvents EventFollow[]
  notifications  Notification[]

  // 用户关注关系
  followers      UserFollow[]   @relation("UserFollowers")  // 关注我的人
  following      UserFollow[]   @relation("UserFollowing")  // 我关注的人

  // 认证申请
  verificationRequests VerificationRequest[]

  // 个人信息
  idDocuments   UserIdDocument[]
  addresses     UserAddress[]

  @@map("users")
  @@index([email])
  @@index([phone])
  @@index([wechatOpenId])
  @@index([qqOpenId])
}

// ✅ 登录日志表
model LoginLog {
  id         String   @id @default(uuid())
  userId     String
  ipAddress  String?
  userAgent  String?
  location   String?
  success    Boolean  @default(true)
  failReason String?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("login_logs")
  @@index([userId])
  @@index([createdAt])
  @@index([success])
}

// ✅ 用户会话表
model UserSession {
  id            String   @id @default(uuid())
  userId        String
  refreshToken  String   @unique
  deviceInfo    String?
  ipAddress     String?
  expiresAt     DateTime
  revoked       Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
  @@index([userId])
  @@index([expiresAt])
  @@index([refreshToken])
}

// ✅ 验证码表
model VerificationCode {
  id        String   @id @default(uuid())
  email     String?  // 邮箱（与 phone 二选一）
  phone     String?  // 手机号（与 email 二选一）
  code      String
  type      String   @default("register")
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("verification_codes")
  @@index([email, type])
  @@index([phone, type])
  @@index([expiresAt])
}

// ==================== 收藏品系统 ====================

// ✅ 收藏品表
model Collectible {
  id            String   @id @default(uuid())
  name          String
  description   String   @db.Text
  imageUrl      String

  // 分类
  category      String   // badge, ticket_stub, poster, certificate, art

  // 关联
  eventId       Int?
  tierId        Int?

  // 3D/AR 展示
  has3DModel    Boolean  @default(false)
  model3DUrl    String?
  modelFormat   String?
  hasAnimation  Boolean  @default(false)
  animationUrl  String?
  modelConfig   String?  @db.Text

  // 供应控制
  totalSupply   Int
  claimedCount  Int      @default(0)

  // 状态
  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // 关联
  event         Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  userCollectibles UserCollectible[]

  @@map("collectibles")
  @@index([eventId])
  @@index([category])
  @@index([isActive])
}

// ✅ 用户收藏记录表
model UserCollectible {
  id            String   @id @default(uuid())
  userId        String
  collectibleId String

  // 获取方式
  sourceType    String   // ticket_purchase, gift, achievement
  sourceId      String?  // 来源ID（订单ID等）

  obtainedAt    DateTime @default(now())

  // 关联
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  collectible   Collectible @relation(fields: [collectibleId], references: [id], onDelete: Restrict)

  @@map("user_collectibles")
  @@index([userId])
  @@index([collectibleId])
  @@index([obtainedAt])
}

// ==================== 社交系统 ====================

model Post {
  id          String   @id @default(uuid())
  userId      String
  content     String   @db.Text
  eventId     Int?
  location    String?
  viewCount   Int      @default(0)
  likeCount   Int      @default(0)
  commentCount Int     @default(0)
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  event       Event?     @relation(fields: [eventId], references: [id], onDelete: SetNull)
  images      PostImage[]
  likes       PostLike[]
  comments    Comment[]
  views       PostView[]
  reports     PostReport[]
  favorites   PostFavorite[]

  @@map("posts")
  @@index([userId])
  @@index([eventId])
  @@index([createdAt])
  @@index([likeCount])
  @@index([isVisible])
}

model PostImage {
  id        String   @id @default(uuid())
  postId    String
  imageUrl  String
  width     Int?
  height    Int?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("post_images")
  @@index([postId])
  @@index([order])
}

model PostLike {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("post_likes")
  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@index([createdAt])
}

model PostView {
  id        String   @id @default(uuid())
  postId    String
  userId    String?
  ipAddress String?
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("post_views")
  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@index([createdAt])
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  content   String   @db.Text
  parentId  String?
  likeCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")

  @@map("comments")
  @@index([postId])
  @@index([userId])
  @@index([parentId])
  @@index([createdAt])
}

model PostReport {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  reason    String   @db.Text
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("post_reports")
  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model PostFavorite {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("post_favorites")
  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@index([createdAt])
}

// ==================== 聊天系统（私聊 + 群聊） ====================

model Conversation {
  id            String   @id @default(uuid())
  type          String   @default("private") // private(私聊), group(群聊)
  name          String?  // 群名称（群聊时使用）
  avatar        String?  // 群头像
  description   String?  // 群描述
  creatorId     String?  // 群创建者ID
  maxMembers    Int      @default(500) // 最大成员数
  memberCount   Int      @default(0) // 当前成员数
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
  @@index([type])
  @@index([creatorId])
  @@index([lastMessageAt])
}

model ConversationParticipant {
  id             String   @id @default(uuid())
  conversationId String
  userId         String
  role           String   @default("member") // owner(群主), admin(管理员), member(成员)
  nickname       String?  // 群内昵称
  isMuted        Boolean  @default(false) // 是否被禁言
  unreadCount    Int      @default(0)
  lastReadAt     DateTime @default(now())
  joinedAt       DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("conversation_participants")
  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
  @@index([role])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  receiverId     String?  // 私聊时为接收者ID，群聊时为空
  content        String   @db.Text
  messageType    String   @default("text") // text, image, file, system
  isRead         Boolean  @default(false)
  readBy         String?  @db.Text // 群聊时记录已读成员ID列表（JSON数组）
  createdAt      DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver       User?        @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@map("messages")
  @@index([conversationId])
  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
  @@index([isRead])
}

// ==================== 关注系统 ====================

model EventFollow {
  id        String   @id @default(uuid())
  userId    String
  eventId   Int
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_follows")
  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  content   String   @db.Text
  eventId   Int?
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@map("notifications")
  @@index([userId])
  @@index([eventId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
}

// ✅ 用户关注表
model UserFollow {
  id          String   @id @default(uuid())
  followerId  String   // 关注者ID
  followingId String   // 被关注者ID
  createdAt   DateTime @default(now())

  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("user_follows")
  @@index([followerId])
  @@index([followingId])
  @@index([createdAt])
}

// ✅ 身份认证申请表
model VerificationRequest {
  id              String   @id @default(uuid())
  userId          String
  verifiedType    String   // celebrity, artist, organizer, official
  realName        String   // 真实姓名
  idCard          String?  // 身份证号（加密存储）
  organization    String?  // 所属机构/公司
  proofImages     String   @db.Text // 证明材料图片URLs（JSON数组）
  reason          String   @db.Text // 申请理由
  status          String   @default("pending") // pending, approved, rejected
  reviewedBy      String?  // 审核人ID
  reviewedAt      DateTime?
  rejectReason    String?  @db.Text // 拒绝理由
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verification_requests")
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ==================== 首页栏目管理 ====================

// 首页栏目表
model HomepageSection {
  id          String   @id @default(uuid())
  title       String   // 栏目标题，如"猜你喜欢"、"演唱会专区"
  subtitle    String?  // 副标题，如"根据你的兴趣为你推荐"
  icon        String?  // 图标emoji，如"✨"、"🎤"
  bgGradient  String   @default("from-purple-50 to-pink-50") // Tailwind渐变类
  moreLink    String?  // "查看更多"链接
  order       Int      // 显示顺序
  isActive    Boolean  @default(true) // 是否启用
  type        String   @default("manual") // manual(手动), auto_category(自动按分类), auto_status(自动按状态)
  autoConfig  String?  @db.Text // 自动配置（JSON），如 {"category": "concert", "limit": 6}
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events      HomepageSectionEvent[]

  @@map("homepage_sections")
  @@index([order])
  @@index([isActive])
}

// 首页栏目活动关联表
model HomepageSectionEvent {
  id        String   @id @default(uuid())
  sectionId String   // 所属栏目
  eventId   Int      // 活动ID
  order     Int      // 在栏目中的显示顺序
  createdAt DateTime @default(now())

  section   HomepageSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  event     Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("homepage_section_events")
  @@unique([sectionId, eventId])
  @@index([sectionId])
  @@index([eventId])
  @@index([order])
}

// ==================== 票务转让系统 ====================

// 票务转让记录表
model TicketTransfer {
  id              String   @id @default(uuid())
  ticketId        String   // 转让的门票ID
  fromUserId      String   // 转让人
  toUserId        String?  // 接收人（确认后填写）
  toUserPhone     String?  // 接收人手机号（用于短信通知）
  toUserEmail     String?  // 接收人邮箱（用于邮件通知）
  transferCode    String   @unique // 转让码（用于接收）
  message         String?  @db.Text // 转让留言
  transferType    String   @default("gift") // gift(赠送), sale(转让)
  price           Int?     // 转让价格（仅转让时）
  status          String   @default("pending") // pending(待接收), accepted(已接收), rejected(已拒绝), expired(已过期), cancelled(已取消)
  expiresAt       DateTime // 过期时间
  acceptedAt      DateTime?
  rejectedAt      DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("ticket_transfers")
  @@index([ticketId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([transferCode])
  @@index([status])
  @@index([expiresAt])
}

// ==================== 首页轮播广告栏 ====================

// 首页 Hero Banner 轮播图
model HeroBanner {
  id        String   @id @default(uuid())
  title     String   // 标题，如"音乐节狂欢季"
  subtitle  String   // 副标题，如"感受音乐的力量，释放青春的激情"
  image     String   // 图片URL
  link      String   // 点击跳转链接
  color     String   @default("from-purple-600/80 to-pink-600/80") // Tailwind渐变遮罩类
  order     Int      // 显示顺序
  isActive  Boolean  @default(true) // 是否启用
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hero_banners")
  @@index([order])
  @@index([isActive])
}

// ==================== 个人信息管理系统 ====================

// 用户证件信息表
model UserIdDocument {
  id               String    @id @default(uuid())
  userId           String

  // ============ 证件基本信息 ============
  idType           String    // china_id(身份证), passport(护照), hk_permit(港澳通行证), tw_permit(台湾通行证)
  fullName         String    // 证件上的姓名
  idNumber         String    // 证件号码

  // ============ 证件有效期 ============
  issueDate        DateTime? // 签发日期
  expiryDate       DateTime? // 有效期至
  issuingAuthority String?   // 签发机关

  // ============ 护照特有字段 ============
  nationality      String?   // 国籍（护照）
  birthDate        DateTime? // 出生日期
  gender           String?   // 性别 male/female

  // ============ 默认标记 ============
  isDefault        Boolean   @default(false)

  // ============ 时间戳 ============
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // 关联
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_id_documents")
  @@index([userId])
  @@index([idType])
  @@index([isDefault])
  @@unique([userId, idType, idNumber])
}

// 用户地址表
model UserAddress {
  id             String   @id @default(uuid())
  userId         String

  // ============ 收件人信息 ============
  recipientName  String   // 收件人姓名
  recipientPhone String   // 收件人电话

  // ============ 地址层级结构 ============
  country        String   @default("中国") // 国家
  province       String   // 省/直辖市/自治区/州
  city           String   // 市
  district       String   // 区/县
  street         String?  // 街道/乡镇
  addressDetail  String   // 详细地址（建筑、楼栋、房间号）

  // ============ 邮编 ============
  postalCode     String?  // 邮政编码

  // ============ 标签和备注 ============
  label          String?  // 地址标签：home(家), work(公司), other(其他)

  // ============ 默认标记 ============
  isDefault      Boolean  @default(false)

  // ============ 时间戳 ============
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // 关联
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_addresses")
  @@index([userId])
  @@index([isDefault])
  @@index([country])
}
